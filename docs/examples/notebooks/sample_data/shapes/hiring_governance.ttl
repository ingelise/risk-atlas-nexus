@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix nexus: <https://ibm.github.io/ai-atlas-nexus/ontology/> .

nexus:HiringRiskShape a sh:NodeShape ;
    sh:targetClass nexus:Risk ;
    sh:property [ sh:path nexus:isDefinedByTaxonomy ; sh:minCount 1 ] ;
    sh:rule [
        a sh:SPARQLRule ;
        sh:construct """
PREFIX nexus: <https://ibm.github.io/ai-atlas-nexus/ontology/>
CONSTRUCT { ?this nexus:requiresGovernance true }
WHERE {
    ?this a nexus:Risk ;
          nexus:isDefinedByTaxonomy "hiring-usecase-demo" .
}
"""
    ] .
